# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Runtime / local only
logs/
*.log
nohup.out

# Buffers / intermediate (NOT source texts)
data/_cache/

# Backup dirs (not source texts — transient processing copies)
data/_raw_no_punct/clean_backup_*/
data/_raw_no_punct/user_upload_backup/
data/_raw_no_punct/**/user_upload*/

# Local-only private corpus (never push). Use data/_private/ or .git/info/exclude.
data/_private/
**/user_private/**

# Note: raw public-domain sources under data/_raw_no_punct/ (*.txt) ARE tracked.
# Non-public-domain modern editions must stay local-only.

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Local experiment stubs (kept out of repo root noise)
wikisource_test*.py
wikisource_search*.py
wikisource_prefix.py
wikisource_download.py

# Duplicate legacy UI at project root (canonical is static/index.html)
/index.html

# Local resegment/repair snapshots (not source corpus)
*.bak
*.bak_*
**/*.bak_before_*
data/**/*.bak_before_*
data/_raw_no_punct/**/user_upload*/
.env
.env.*
**/*.pem
**/*credentials*
